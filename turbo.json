{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "globalDependencies": [
    "tsconfig.base.json",
    ".env.example",
    ".env",
    "apps/api/.env",
    "apps/web/.env.development",
    "apps/web/.env.production"
  ],
  "boundaries": {
    "tags": {
      "foundation": {
        "dependencies": {
          "deny": ["foundation", "data", "presentation", "app-server", "app-client", "tooling"]
        }
      },
      "data": {
        "dependencies": {
          "allow": ["foundation"]
        }
      },
      "presentation": {
        "dependencies": {
          "allow": ["foundation"]
        }
      },
      "app-server": {
        "dependencies": {
          "allow": ["data", "foundation"]
        }
      },
      "app-client": {
        "dependencies": {
          "allow": ["presentation", "foundation"]
        }
      },
      "tooling": {
        "dependencies": {
          "deny": ["foundation", "data", "presentation", "app-server", "app-client", "tooling"]
        }
      }
    }
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vite/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": ["coverage/**"]
    },
    "meta:introspect": {
      "dependsOn": ["build"],
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "outputs": ["src/db/migrations/**"]
    },
    "test:db": {
      "dependsOn": ["^transit"],
      "outputs": ["coverage/**"]
    },
    "check:all": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "gate:early": {
      "dependsOn": ["check:all"],
      "outputs": []
    }
  }
}
