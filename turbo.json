{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vite/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": ["coverage/**"]
    },
    "meta:introspect": {
      "dependsOn": ["build"],
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "outputs": ["src/db/migrations/**"]
    },
    "test:db": {
      "dependsOn": ["^transit"],
      "outputs": ["coverage/**"]
    },
    "check:all": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "gate:early": {
      "dependsOn": ["check:all"],
      "outputs": []
    }
  }
}
