# ============================================================================
# AFENDA — Next.js App Environment (source of truth for production)
# Sync into .env for production: pnpm run sync:env  (or node scripts/sync-env-config-to-env.mjs)
# Root .env is for drizzle-kit, scripts, and non-Next packages.
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
VITE_LOG_LEVEL=debug
VITE_APP_TITLE=AFENDA
PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=your-session-secret-change-in-production

# ── Dev Credentials ──────────────────────────────────────────────────────────
ENABLE_DEV_CREDENTIALS=true
DEV_AUTH_USERNAME=admin
DEV_AUTH_PASSWORD=admin

# ── Neon Database (production branch) ────────────────────────────────────────
# Runtime: pooled connection via PgBouncer (serverless-safe, high concurrency)
# sslnegotiation=direct: faster SSL handshake (Postgres 17+ client)
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require&channel_binding=require&sslnegotiation=direct
# Migrations: direct TCP (no pooler) — required for DDL, advisory locks, CREATE INDEX CONCURRENTLY
DATABASE_URL_MIGRATIONS=postgresql://user:password@host.neon.tech/dbname?sslmode=require&sslnegotiation=direct
# Worker: direct TCP (no pooler) — Graphile Worker uses LISTEN/NOTIFY, incompatible with PgBouncer
WORKER_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&sslnegotiation=direct
# Pool tuning (optional): DB_POOL_MAX=5, DB_IDLE_TIMEOUT_MS=10000 for Neon scale-to-zero
NEON_PROJECT_ID=your-neon-project-id
NEON_BRANCH_ID=your-neon-branch-id
NEON_API_KEY=your-neon-api-key
# For Neon Auth passwordless: -h pg.neon.tech
NEON_PASSWORDLESS_AUTH=-h pg.neon.tech

# ── Neon Auth (active) ────────────────────────────────────────────────────────
# Troubleshooting 7-step checklist: see docs/neon-auth-nextjs-server-reference.md
# 1. Absolute callback URL → from BASE_URL/AUTH_URL below (no trailing slash)
# 2. baseUrl no trailing slash → NEON_AUTH_BASE_URL is normalized in code
# 3. Trusted origins → add this app origin in Neon Console → Auth → Trusted domains
# 4. BASE_URL / AUTH_URL → required for getBaseUrl(); production: use https://yourapp.com
# 5. Cookie secret 32+ chars → NEON_AUTH_COOKIE_SECRET (base64 32 bytes recommended)
# 6. Session TTL (optional) → set if sessions drop
# 7. Cookie domain (optional) → set in production for subdomains
NEON_AUTH_BASE_URL=https://your-neon-auth-instance.neonauth.region.aws.neon.tech/dbname/auth
NEON_AUTH_COOKIE_SECRET=your-base64-32-byte-cookie-secret
NEXT_PUBLIC_NEON_AUTH_URL=https://your-neon-auth-instance.neonauth.region.aws.neon.tech/dbname/auth
NEON_AUTH_JWKS_URL=https://your-neon-auth-instance.neonauth.region.aws.neon.tech/dbname/auth/.well-known/jwks.json
NEON_AUTH_SESSION_TTL=300
# Production only (omit for localhost): e.g. .nexuscanon.com for *.nexuscanon.com
# NEON_AUTH_COOKIE_DOMAIN=.yourdomain.com

# ── Neon Data API ────────────────────────────────────────────────────────────
# Server / server-side usage (e.g. serverless, API routes)
NEON_DATA_API_URL=https://your-neon-data-api.apirest.region.aws.neon.tech/dbname/rest/v1
# Client-side (@neondatabase/neon-js createClient): set for browser Data API (client.from().select())
# NEXT_PUBLIC_NEON_DATA_API_URL=https://your-neon-data-api.apirest.region.aws.neon.tech/dbname/rest/v1

# ── Auth App URL (for callbacks/links) ──────────────────────────────────────
# Required for Neon Auth absolute callback URL (getBaseUrl()). Production: set to app origin (e.g. https://nexuscanon.com).
AUTH_URL=http://localhost:3000

# ── Auth Challenges (MFA, invite, reset) ─────────────────────────────────────
# HMAC secret for challenge token hashing; use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_CHALLENGE_SECRET=your-auth-challenge-secret-hex-string

# ── Auth Evidence (export signing) ───────────────────────────────────────────
AUTH_EVIDENCE_SIGNING_SECRET=your-auth-evidence-signing-secret-hex-string

# ── OAuth Providers (Neon Auth managed) ─────────────────────────────────────
# Configure Google/GitHub providers in Neon Console for this Neon Auth project.
# App env does not require AUTH_GOOGLE_* / AUTH_GITHUB_* or legacy *_CLIENT_* keys.

# ── Cloudflare R2 Storage ────────────────────────────────────────────────────
# Neon + R2 pattern: metadata in Neon, files in R2; use presigned URLs for upload/download.
# See: https://neon.com/docs/guides/cloudflare-r2 and .dev-note R2+Neon section.
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# Optional: public bucket URL for direct read links (e.g. https://pub-xxx.r2.dev). Omit for private buckets.
# R2_PUBLIC_BASE_URL=https://pub-your-bucket.r2.dev
# Optional: Orchestra backup bucket; if unset, backups use R2_BUCKET_NAME.
# R2_BACKUP_BUCKET=your-backup-bucket
# API requires S3_* (R2 is S3-compatible)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=your-r2-bucket-name
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key

# ── Observability (Grafana OTEL + GlitchTip) ────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-region.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20your-base64-encoded-credentials
OTEL_SERVICE_NAME=your-app-name
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TOKEN=glc_your-grafana-token
SENTRY_DSN=https://your-sentry-dsn@app.glitchtip.com/project-id

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
DEFAULT_FROM_NAME=Your App Name

# ── Figma ────────────────────────────────────────────────────────────────────
FIGMA_PERSONAL_ACCESS_TOKEN=figd_your-figma-personal-token
FIGMA_TOKEN=figd_your-figma-token
FIGMA_FILE_KEY=your-figma-file-key

# ── Third-Party API Keys ────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_your-github-token
OPENAI_API_KEY=sk-your-openai-api-key
NPM_ACCESS_TOKEN=npm_your-npm-token
BASEHUB_TOKEN=bshb_pk_your-basehub-token
ARCJET_KEY=ajkey_your-arcjet-key
POSTHOG_KEY=phc_your-posthog-key

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_CLI_KEY=mk_your-stripe-cli-key
STRIPE_SECRET_KEY=mk_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=mk_your-stripe-publishable-key

# ── BetterStack ──────────────────────────────────────────────────────────────
BETTERSTACK_GLOBAL_API_KEY=your-betterstack-global-api-key
BETTERSTACK_UPTIME_API_TOKEN=your-betterstack-uptime-token
BETTERSTACK_TELEMETRY_API_TOKEN=your-betterstack-telemetry-token
SENTRY=sntryu_your-sentry-token

# ── Redis (Upstash + RedisLabs) ──────────────────────────────────────────────
REDIS_HOST=redis-your-instance.region.ec2.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://default:your-redis-password@redis-your-instance.region.ec2.cloud.redislabs.com:12345

# ── Deployment ───────────────────────────────────────────────────────────────
VERCEL_TOKEN=your-vercel-token
RAILWAY_TOKEN=your-railway-token
RAILWAY_PROJECT_URL=https://railway.com/project/your-project-id
TURBO_TOKEN=your-turbo-token
TURBO_TEAM=team_your-turbo-team-id
