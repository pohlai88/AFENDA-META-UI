# AFENDA Platform — Configuration

# ============================================================================
# Database
# ============================================================================
# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/afenda

# ============================================================================
# Server
# ============================================================================
# Port to listen on
PORT=4000

# ============================================================================
# Authentication
# ============================================================================
# JWT secret for signing and verifying tokens
# Change this to a strong random value in production!
JWT_SECRET=change-me-in-production-use-a-strong-random-string

# ============================================================================
# CORS
# ============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Environment
# ============================================================================
# Set to 'production' to disable introspection, enable error masking
NODE_ENV=development
