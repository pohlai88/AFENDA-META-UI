# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# TypeScript/JavaScript files
# charset is re-declared explicitly: editors must always save these files as
# UTF-8. Never paste text copied from a Windows-1252 / Latin-1 environment
# directly into source — use ASCII-safe equivalents in comments and strings.
[*.{ts,tsx,js,jsx,mjs,cjs}]
charset = utf-8
indent_size = 2

# Package.json
[package.json]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf

# Makefiles
[Makefile]
indent_style = tab

# SQL files
[*.sql]
indent_size = 2

# Configuration files
[*.config.{ts,js,mjs,cjs}]
indent_size = 2

# .env files
[.env*]
trim_trailing_whitespace = false
