# Development environment variables
# These are loaded automatically when running `vite` (dev mode)

VITE_API_URL=http://localhost:4000
VITE_APP_TITLE=AFENDA (Dev)
VITE_APP_ENV=development
VITE_NOTIFICATION_TOAST_DEDUPE_MS=2500
VITE_PERMISSIONS_BOOTSTRAP_ENDPOINT=/meta/bootstrap

# Analytics — console only in development (no data sent to PostHog)
VITE_ANALYTICS_PROVIDERS=console
VITE_ANALYTICS_BATCH_SIZE=5
VITE_ANALYTICS_FLUSH_INTERVAL_MS=2000
