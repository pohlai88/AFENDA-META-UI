# AFENDA API Environment Configuration
# =====================================
# Copy this file to .env and customize for your environment

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string
# Production: Add ?sslmode=require for encrypted connections
DATABASE_URL=postgresql://user:password@localhost:5432/afenda

# ---------------------------------------------------------------------------
# Security - JWT Authentication
# ---------------------------------------------------------------------------
# CRITICAL: Generate a strong secret with: openssl rand -base64 32
# Must be 32+ characters in production
JWT_SECRET=change-me-in-production

# Token expiry (uses vercel/ms format: 1h, 24h, 7d, etc.)
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Security - API Keys (Service-to-Service Auth)
# ---------------------------------------------------------------------------
# Comma-separated list of valid API keys
# Generate secure keys with: openssl rand -hex 32
API_KEYS=
API_KEY_HEADER=X-API-Key

# ---------------------------------------------------------------------------
# CORS Configuration
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Development: http://localhost:5173
# Production: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Enable/disable rate limiting (disable for load testing)
RATE_LIMIT_ENABLED=true

# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Request Body Parsing
# ---------------------------------------------------------------------------
# Maximum request body size
BODY_LIMIT=2mb

# ---------------------------------------------------------------------------
# Compression
# ---------------------------------------------------------------------------
# Enable response compression (recommended for production)
COMPRESSION_ENABLED=true

# ---------------------------------------------------------------------------
# Uploads - Request Limits
# ---------------------------------------------------------------------------
# Maximum upload size in bytes (default: 10MB)
UPLOAD_MAX_BYTES=10485760

# ---------------------------------------------------------------------------
# Upload Storage Provider
# ---------------------------------------------------------------------------
# local | r2
UPLOAD_STORAGE_PROVIDER=local

# ---------------------------------------------------------------------------
# Cloudflare R2 (required when UPLOAD_STORAGE_PROVIDER=r2)
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: path prefix inside bucket (e.g. uploads)
R2_KEY_PREFIX=

# Optional: public base URL for served objects
# Example: https://assets.yourdomain.com
R2_PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# Upload Retention / Orphan Cleanup Job
# ---------------------------------------------------------------------------
# Enable periodic cleanup for orphaned uploads
UPLOAD_RETENTION_ENABLED=false

# Delete uploads older than this many milliseconds (default: 30 days)
UPLOAD_RETENTION_MAX_AGE_MS=2592000000

# Cleanup run interval in milliseconds (default: 6 hours)
UPLOAD_RETENTION_INTERVAL_MS=21600000
