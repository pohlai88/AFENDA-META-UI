{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "meta:introspect": "tsx src/meta/introspect-cli.ts",
    "auth:token": "tsx src/utils/generateToken.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@afenda/db": "workspace:*",
    "@afenda/meta-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1016.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-graphql": "^0.8.0",
    "drizzle-orm": "1.0.0-beta.19",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "7.2.1",
    "filtrex": "^3.1.0",
    "graphql": "^16.8.1",
    "graphql-yoga": "^5.0.0",
    "helmet": "^7.1.0",
    "jose": "^5.2.4",
    "multer": "^2.1.1",
    "pg": "^8.11.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "commander": "^14.0.3",
    "drizzle-kit": "1.0.0-beta.19",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
