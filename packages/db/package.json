{
  "name": "@afenda/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./truth-compiler": {
      "import": "./dist/truth-compiler/index.js",
      "types": "./dist/truth-compiler/index.d.ts"
    },
    "./shared": {
      "import": "./dist/_shared/index.js",
      "types": "./dist/_shared/index.d.ts"
    },
    "./session": {
      "import": "./dist/_session/index.js",
      "types": "./dist/_session/index.d.ts"
    },
    "./rls": {
      "import": "./dist/_rls/index.js",
      "types": "./dist/_rls/index.d.ts"
    },
    "./relations": {
      "import": "./dist/relations.js",
      "types": "./dist/relations.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./schema-meta": {
      "import": "./dist/schema-meta/index.js",
      "types": "./dist/schema-meta/index.d.ts"
    },
    "./schema-domain": {
      "import": "./dist/schema-domain/index.js",
      "types": "./dist/schema-domain/index.d.ts"
    },
    "./schema-platform": {
      "import": "./dist/schema-platform/index.js",
      "types": "./dist/schema-platform/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "pnpm --filter @afenda/meta-types build && tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:trigger:apply": "tsx src/_maintenance/apply-status-triggers.ts",
    "db:trigger:dry": "tsx src/_maintenance/apply-status-triggers.ts --dry-run",
    "ops:retention:plan": "tsx src/_maintenance/run-sales-retention.ts --dry-run",
    "ops:retention:apply": "tsx src/_maintenance/run-sales-retention.ts --apply",
    "ops:partition:plan": "tsx src/_maintenance/run-sales-partition-plan.ts --dry-run",
    "ops:partition:apply": "tsx src/_maintenance/run-sales-partition-plan.ts --apply",
    "test:db": "vitest run --passWithNoTests",
    "test:graph-validation": "vitest run --passWithNoTests src/graph-validation/__test__",
    "test:graph-validation:coverage": "vitest run --coverage --passWithNoTests src/graph-validation/__test__",
    "check:all": "pnpm run typecheck && pnpm run truth:check && pnpm run test:db",
    "gate:early": "pnpm run check:all",
    "seed": "tsx src/_seeds/index.ts",
    "archival": "tsx src/archival/runner.ts",
    "graph-validation": "tsx src/graph-validation/runner.ts",
    "truth:generate": "tsx src/truth-compiler/generate-truth-sql.ts",
    "truth:check": "tsx src/truth-compiler/generate-truth-sql.ts --check",
    "truth:schema:compare": "tsx src/truth-compiler/compare-truth-schema.ts"
  },
  "dependencies": {
    "@afenda/meta-types": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "dotenv": "^17.3.1",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
