{
  "name": "@afenda/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --cache --cache-location .cache/eslint/.eslintcache --cache-strategy content --concurrency auto",
    "lint:strict": "eslint src --max-warnings=0 --no-warn-ignored --concurrency auto",
    "lint:fix": "eslint src --fix --cache --cache-location .cache/eslint/.eslintcache --cache-strategy content --concurrency auto",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^1.0.0",
    "radix-ui": "^1.4.3",
    "date-fns": "^3.6.0",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.72.0",
    "next-themes": "^0.4.6",
    "cmdk": "^1.1.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.0",
    "typescript": "catalog:"
  }
}
