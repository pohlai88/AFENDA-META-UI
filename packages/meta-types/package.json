{
  "name": "@afenda/meta-types",
  "description": "Canonical business truth contract — entities, events, invariants, and state transitions for the AFENDA metadata engine",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./rbac": {
      "import": "./dist/rbac/index.js",
      "types": "./dist/rbac/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/compiler/index.js",
      "types": "./dist/compiler/index.d.ts"
    },
    "./module": {
      "import": "./dist/module/index.js",
      "types": "./dist/module/index.d.ts"
    },
    "./layout": {
      "import": "./dist/layout/index.js",
      "types": "./dist/layout/index.d.ts"
    },
    "./policy": {
      "import": "./dist/policy/index.js",
      "types": "./dist/policy/index.d.ts"
    },
    "./audit": {
      "import": "./dist/audit/index.js",
      "types": "./dist/audit/index.d.ts"
    },
    "./events": {
      "import": "./dist/events/index.js",
      "types": "./dist/events/index.d.ts"
    },
    "./graph": {
      "import": "./dist/graph/index.js",
      "types": "./dist/graph/index.d.ts"
    },
    "./mesh": {
      "import": "./dist/mesh/index.js",
      "types": "./dist/mesh/index.d.ts"
    },
    "./workflow": {
      "import": "./dist/workflow/index.js",
      "types": "./dist/workflow/index.d.ts"
    },
    "./platform": {
      "import": "./dist/platform/index.js",
      "types": "./dist/platform/index.d.ts"
    },
    "./inventory": {
      "import": "./dist/inventory/index.js",
      "types": "./dist/inventory/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:strict": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run",
    "test:contracts": "vitest run src/__test__/api-contract.test.ts src/__test__/integration/type-contracts.test.ts src/__test__/integration/dependency-chains.test.ts",
    "test:schema": "vitest run src/schema/__test__/schema.test.ts src/rbac/__test__/schema.test.ts src/workflow/__test__/schema.test.ts src/platform/__test__/tenant.schema.test.ts src/inventory/__test__/schema.test.ts",
    "test:types": "tsc --noEmit",
    "gate:export-snapshot": "vitest run src/__test__/api-contract.test.ts"
  },
  "peerDependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
