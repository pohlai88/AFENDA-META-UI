{
  "name": "afenda-meta-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:verbose": "turbo run typecheck -- --listFilesOnly --explainFiles",
    "typecheck:debug": "turbo run typecheck -- --listFiles --pretty=false",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "ci:contracts": "pnpm --filter @afenda/web run test:contracts",
    "ci:gate": "node tools/ci-gate/index.mjs",
    "ci:gate:fix": "node tools/ci-gate/index.mjs --fix",
    "ci:gate:verbose": "node tools/ci-gate/index.mjs --verbose",
    "ci:deps": "pnpm ci:deps:audit && pnpm ci:deps:outdated && pnpm ci:gate:dependencies",
    "ci:deps:audit": "pnpm audit --audit-level=high",
    "ci:deps:outdated": "pnpm outdated --recursive || echo Outdated dependencies reported",
    "ci:gate:logger": "node tools/ci-gate/index.mjs --gate=logger",
    "ci:gate:dependencies": "node tools/ci-gate/index.mjs --gate=dependencies",
    "ci:gate:typescript": "node tools/ci-gate/index.mjs --gate=typescript",
    "ci:gate:bundle": "node tools/ci-gate/bundle/index.mjs",
    "ci:gate:bundle:update": "node tools/ci-gate/bundle/index.mjs --update",
    "ci:gate:bundle:report": "node tools/ci-gate/bundle/index.mjs --report",
    "ci:gate:vite": "node tools/ci-gate/index.mjs --gate=vite",
    "ci:gate:vite:fix": "node tools/ci-gate/index.mjs --gate=vite --fix",
    "ci:gate:vite:verbose": "node tools/ci-gate/index.mjs --gate=vite --verbose",
    "ci:logger": "node tools/ci-gate/logger/index.mjs",
    "ci:logger:fix": "node tools/ci-gate/logger/index.mjs --fix",
    "ci:gate:boundaries": "node tools/ci-gate/boundaries/index.mjs",
    "ci:gate:boundaries:fix": "node tools/ci-gate/boundaries/index.mjs --fix",
    "ci:gate:boundaries:verbose": "node tools/ci-gate/boundaries/index.mjs --verbose",
    "ci:gate:circular": "node tools/ci-gate/circular/index.mjs",
    "ci:gate:circular:verbose": "node tools/ci-gate/circular/index.mjs --verbose",
    "knip": "knip",
    "knip:production": "knip --production",
    "knip:fix": "knip --fix",
    "syncpack": "syncpack lint",
    "syncpack:list": "syncpack list-mismatches",
    "syncpack:fix": "syncpack fix-mismatches",
    "syncpack:format": "syncpack format",
    "sherif": "sherif",
    "validate:ci:state": "pnpm --filter web validate:ci:state",
    "validate:ci:phase2": "pnpm --filter web validate:ci:phase2",
    "validate:ci:phase3": "pnpm --filter web validate:ci:phase3",
    "validate:ci:phase3:pages": "pnpm --filter web validate:ci:phase3:pages",
    "validate:ci:phase4": "pnpm --filter web validate:ci:phase4",
    "db:push": "pnpm --filter api db:push",
    "db:generate": "pnpm --filter api db:generate",
    "db:push:api": "pnpm --filter api db:push",
    "db:generate:api": "pnpm --filter api db:generate",
    "db:push:db": "pnpm --filter @afenda/db db:push",
    "db:generate:db": "pnpm --filter @afenda/db db:generate",
    "db:test": "pnpm --filter @afenda/db test:db",
    "db:check": "pnpm --filter @afenda/db check:all",
    "db:introspect": "pnpm --filter api meta:introspect"
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2"
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "devDependencies": {
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-boundaries": "^6.0.1",
    "glob": "^13.0.6",
    "knip": "^6.0.5",
    "madge": "^8.0.0",
    "prettier": "catalog:",
    "sherif": "^1.11.0",
    "syncpack": "^14.2.1",
    "turbo": "^2.8.20",
    "typescript": "catalog:"
  }
}
