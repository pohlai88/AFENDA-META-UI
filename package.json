{
  "name": "afenda-meta-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "ci:contracts": "pnpm --filter @afenda/web run test:contracts",
    "ci:gate": "node tools/ci-gate/index.mjs",
    "ci:gate:fix": "node tools/ci-gate/index.mjs --fix",
    "ci:gate:verbose": "node tools/ci-gate/index.mjs --verbose",
    "ci:deps": "pnpm ci:deps:audit && pnpm ci:deps:outdated && pnpm ci:gate:dependencies",
    "ci:deps:audit": "pnpm audit --audit-level=high",
    "ci:deps:outdated": "pnpm outdated --recursive || echo Outdated dependencies reported",
    "ci:gate:logger": "node tools/ci-gate/index.mjs --gate=logger",
    "ci:gate:dependencies": "node tools/ci-gate/index.mjs --gate=dependencies",
    "ci:logger": "node tools/ci-gate/logger/index.mjs",
    "ci:logger:fix": "node tools/ci-gate/logger/index.mjs --fix",
    "validate:ci:state": "pnpm --filter web validate:ci:state",
    "validate:ci:phase2": "pnpm --filter web validate:ci:phase2",
    "validate:ci:phase3": "pnpm --filter web validate:ci:phase3",
    "validate:ci:phase3:pages": "pnpm --filter web validate:ci:phase3:pages",
    "validate:ci:phase4": "pnpm --filter web validate:ci:phase4",
    "db:push": "pnpm --filter api db:push",
    "db:generate": "pnpm --filter api db:generate",
    "db:push:api": "pnpm --filter api db:push",
    "db:generate:api": "pnpm --filter api db:generate",
    "db:push:db": "pnpm --filter @afenda/db db:push",
    "db:generate:db": "pnpm --filter @afenda/db db:generate",
    "db:test": "pnpm --filter @afenda/db test:db",
    "db:check": "pnpm --filter @afenda/db check:all",
    "db:introspect": "pnpm --filter api meta:introspect"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "1.0.0-beta.19",
      "drizzle-kit": "1.0.0-beta.19",
      "zod": "^4.3.6",
      "vitest": "^4.1.1",
      "tsx": "^4.21.0",
      "pg": "^8.20.0",
      "@types/pg": "^8.20.0",
      "@types/node": "^22.0.0",
      "typescript": "^5.9.0",
      "flatted": "^3.4.2"
    }
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "prettier": "^3.8.1",
    "turbo": "^1.13.4",
    "typescript": "^5.9.0"
  }
}
