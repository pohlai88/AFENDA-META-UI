{
  "name": "afenda-meta-ui",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "prepare": "husky",
    "env:sync": "node tools/scripts/sync-env-config-to-env.mjs",
    "sync:env": "pnpm env:sync",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "lint": "turbo run lint",
    "lint:affected": "turbo run lint --affected",
    "lint:strict": "turbo run lint -- --max-warnings=0 --no-warn-ignored",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected",
    "typecheck:verbose": "turbo run typecheck -- --listFilesOnly --explainFiles",
    "typecheck:debug": "turbo run typecheck -- --listFiles --pretty=false",
    "test:affected": "turbo run test --affected",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,yml,yaml}\"",
    "ci:contracts": "pnpm --filter @afenda/web run test:contracts",
    "ci:gate": "node tools/ci-gate/index.mjs",
    "ci:gate:full": "node tools/ci-gate/index.mjs --mode=full",
    "ci:gate:fast": "node tools/ci-gate/index.mjs --mode=fast",
    "ci:gate:fast:parallel": "node tools/ci-gate/index.mjs --mode=fast --concurrency=2",
    "ci:gate:fix": "node tools/ci-gate/index.mjs --fix",
    "ci:gate:verbose": "node tools/ci-gate/index.mjs --verbose",
    "ci:deps": "pnpm ci:deps:audit && pnpm ci:deps:outdated && pnpm ci:gate:dependencies",
    "ci:deps:audit": "pnpm audit --audit-level=high",
    "ci:deps:outdated": "pnpm outdated --recursive || echo Outdated dependencies reported",
    "ci:gate:logger": "node tools/ci-gate/index.mjs --gate=logger",
    "ci:gate:casing": "node tools/ci-gate/index.mjs --gate=casing",
    "ci:gate:postgres": "node tools/ci-gate/index.mjs --gate=postgres-schema",
    "ci:gate:truth": "node tools/ci-gate/index.mjs --gate=truth-score",
    "ci:gate:dependencies": "node tools/ci-gate/index.mjs --gate=dependencies",
    "ci:gate:typescript": "node tools/ci-gate/index.mjs --gate=typescript",
    "ci:api:command-bounded-context": "pnpm --filter @afenda/api test:command-bounded-context",
    "ci:api:projection-replay": "pnpm --filter @afenda/api test:projection-replay",
    "ci:gate:bundle": "node tools/ci-gate/bundle/index.mjs",
    "ci:gate:bundle:update": "node tools/ci-gate/bundle/index.mjs --update",
    "ci:gate:bundle:report": "node tools/ci-gate/bundle/index.mjs --report",
    "ci:gate:vite": "node tools/ci-gate/index.mjs --gate=vite",
    "ci:gate:vite:fix": "node tools/ci-gate/index.mjs --gate=vite --fix",
    "ci:gate:vite:verbose": "node tools/ci-gate/index.mjs --gate=vite --verbose",
    "ci:logger": "node tools/ci-gate/logger/index.mjs",
    "ci:logger:fix": "node tools/ci-gate/logger/index.mjs --fix",
    "ci:imports": "node tools/ci-gate/imports/index.mjs",
    "ci:imports:fix": "node tools/ci-gate/imports/index.mjs --fix",
    "fix:console": "node tools/scripts/fix-console-logs.mjs",
    "fix:console:dry": "node tools/scripts/fix-console-logs.mjs --dry-run",
    "ci:gate:boundaries": "node tools/ci-gate/boundaries/index.mjs",
    "ci:gate:boundaries:fix": "node tools/ci-gate/boundaries/index.mjs --fix",
    "ci:gate:boundaries:verbose": "node tools/ci-gate/boundaries/index.mjs --verbose",
    "ci:gate:circular": "node tools/ci-gate/circular/index.mjs",
    "ci:gate:circular:verbose": "node tools/ci-gate/circular/index.mjs --verbose",
    "knip": "knip",
    "knip:production": "knip --production",
    "knip:fix": "knip --fix",
    "syncpack": "syncpack lint",
    "syncpack:list": "syncpack list-mismatches",
    "syncpack:fix": "syncpack fix-mismatches",
    "syncpack:format": "syncpack format",
    "sherif": "sherif",
    "validate:ci:state": "pnpm --filter web validate:ci:state",
    "validate:ci:phase2": "pnpm --filter web validate:ci:phase2",
    "validate:ci:phase3": "pnpm --filter web validate:ci:phase3",
    "validate:ci:phase3:pages": "pnpm --filter web validate:ci:phase3:pages",
    "validate:ci:phase4": "pnpm --filter web validate:ci:phase4",
    "db:push": "pnpm --filter @afenda/db db:push",
    "db:generate": "pnpm --filter @afenda/db db:generate",
    "db:migrate": "pnpm --filter @afenda/db db:migrate",
    "db:push:api": "pnpm --filter @afenda/db db:push",
    "db:generate:api": "pnpm --filter @afenda/db db:generate",
    "db:migrate:api": "pnpm --filter @afenda/db db:migrate",
    "db:push:db": "pnpm --filter @afenda/db db:push",
    "db:generate:db": "pnpm --filter @afenda/db db:generate",
    "db:migrate:db": "pnpm --filter @afenda/db db:migrate",
    "db:test": "pnpm --filter @afenda/db test:db",
    "db:test:graph-validation": "pnpm --filter @afenda/db test:graph-validation",
    "db:test:graph-validation:coverage": "pnpm --filter @afenda/db test:graph-validation:coverage",
    "db:check": "pnpm --filter @afenda/db check:all",
    "db:introspect": "pnpm --filter api meta:introspect",
    "db:generate:demo": "drizzle-kit generate",
    "db:migrate:demo": "drizzle-kit migrate",
    "db:crud:demo": "tsx packages/db/demo/index.ts",
    "neon:branch:create": "node tools/scripts/neon-branch-create.mjs",
    "neon:branch:switch": "node tools/scripts/neon-branch-switch.mjs",
    "neon:setup": "node tools/scripts/neon-setup-db.mjs",
    "neon:setup:no-seed": "node tools/scripts/neon-setup-db.mjs --skip-seed"
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2",
      "picomatch": ">=4.0.4"
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.0.5",
    "madge": "^8.0.0",
    "prettier": "catalog:",
    "sherif": "^1.11.0",
    "syncpack": "^14.2.1",
    "tsx": "catalog:",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "catalog:"
  }
}
