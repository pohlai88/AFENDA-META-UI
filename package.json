{
  "name": "@afenda/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "lint:state": "eslint \"src/stores/**/*.{ts,tsx}\" \"src/components/layout/top-bar.tsx\" \"src/components/layout/app-shell.tsx\" \"src/components/theme-provider.tsx\" --max-warnings 0",
    "lint:phase2": "pnpm lint:state && eslint \"src/hooks/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:phase3": "pnpm lint:phase2 && eslint \"src/lib/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:phase3:pages": "pnpm lint:phase2 && eslint \"src/pages/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:phase4": "pnpm lint:phase3 && eslint \"src/pages/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:unit": "vitest --project unit",
    "test:component": "vitest --project component",
    "test:integration": "vitest --project integration",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:webkit": "playwright test --project=webkit",
    "test:all": "pnpm test:run && pnpm e2e",
    "validate:state": "pnpm validate:phase4",
    "validate:phase2": "pnpm typecheck && pnpm lint:phase2 && vitest run src/stores",
    "validate:phase3": "pnpm typecheck && pnpm lint:phase3 && vitest run src/stores",
    "validate:phase3:pages": "pnpm typecheck && pnpm lint:phase3:pages && vitest run src/stores",
    "validate:phase4": "pnpm typecheck && pnpm lint:phase4 && vitest run src/stores",
    "validate": "pnpm typecheck && pnpm lint && pnpm test:run && pnpm build",
    "validate:ci:state": "pnpm validate:ci:phase4",
    "validate:ci:phase2": "pnpm validate:phase2 && pnpm build",
    "validate:ci:phase3": "pnpm validate:phase3 && pnpm build",
    "validate:ci:phase3:pages": "pnpm validate:phase3:pages && pnpm build",
    "validate:ci:phase4": "pnpm validate:phase4 && pnpm build",
    "validate:ci": "pnpm typecheck && pnpm lint --max-warnings 0 && pnpm test:run && pnpm build",
    "analyze": "vite build --mode analyze",
    "prepare": "husky"
  },
  "dependencies": {
    "@afenda/meta-types": "workspace:*",
    "@afenda/ui": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@rjsf/core": "^5.19.4",
    "@rjsf/utils": "^5.19.4",
    "@rjsf/validator-ajv8": "^5.19.4",
    "@tanstack/react-query": "^5.40.0",
    "@tanstack/react-query-devtools": "^5.40.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "date-fns": "^3.6.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "7.2.1",
    "filtrex": "^3.1.0",
    "lucide-react": "^1.0.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.24.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  }
}
